# Capital.com API Credentials
# Erstelle API Key unter: capital.com → Settings → API Integrations
# 2FA muss vorher aktiviert sein!
CAPITALCOM_EMAIL=deine@email.de
CAPITALCOM_API_KEY=dein-api-key-hier
CAPITALCOM_PASSWORD=dein-api-passwort-hier

# Demo Mode (true = Demo/Paper Trading, false = Live)
# IMMER zuerst mit Demo testen!
CAPITALCOM_DEMO=true
